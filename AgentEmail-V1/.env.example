# ========================================
# AGENT EMAIL AIRIS V1 - CONFIGURACIÓN
# ========================================
# IMPORTANTE: Copiar a .env y ajustar valores

# AMBIENTE
ENVIRONMENT=development
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production

# SERVIDOR
HOST=0.0.0.0
PORT=8000
WORKERS=4

# BASE DE DATOS
DATABASE_URL=sqlite:///./database/agent_email.db
DB_TIMEOUT=5

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=./logs/agent-email.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# SEGURIDAD
JWT_EXPIRE_HOURS=24
JWT_ALGORITHM=HS256
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# RATE LIMITING
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# ENCRIPTACIÓN
ENCRYPTION_KEY_FILE=./.key

# EMAIL IMAP/SMTP
IMAP_TIMEOUT=30
SMTP_TIMEOUT=30
