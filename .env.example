# Configuración de producción - Agent Email AIRIS

# Base de datos (usar la misma de n8n)
DATABASE_URL=postgresql://n8n_user:n8n_password@localhost:5432/n8n_db

# URL de n8n (si está en otro servidor o subdominio)
N8N_URL=http://localhost:5678

# Puerto del servidor API
PORT=8000

# Modo debug (False en producción)
FLASK_DEBUG=False
