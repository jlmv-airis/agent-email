        "path": "asignar-ticket",
        "responseMode": "lastNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 0],
      "id": "webhook-asignar",
      "name": "Webhook Asignar"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE mensajes_entrantes \nSET \n    asignado_a = '{{ $json.body.operador }}', \n    estatus = 'asignado' \nWHERE id = {{ $json.body.ticketId }} \nRETURNING *;"
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [250, 0],
      "id": "db-assign",
      "name": "Actualizar Asignación",
      "credentials": {
        "postgres": {
          "id": "CREDENCIAL_POSTGRES_DOCKER",
          "name": "Postgres Local (Docker)"
        }
      }
    }
  ],
  "connections": {
    "Webhook Asignar": {
      "main": [[{"node": "Actualizar Asignación", "type": "main", "index": 0}]]
    }
  }
