    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT * FROM trazabilidad_logs WHERE cuenta_email = '{{ $json.query.email || $json.body.email }}' ORDER BY fecha DESC LIMIT 5;"
      },
