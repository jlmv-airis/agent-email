      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE mensajes_entrantes SET asignado_a = {{ $json.body.operador ? \"'\" + $json.body.operador + \"'\" : 'NULL' }}, estatus = {{ $json.body.operador ? \"'asignado'\" : \"'pendiente'\" }} WHERE id = {{ $json.body.ticketId }} RETURNING *;"
      },
