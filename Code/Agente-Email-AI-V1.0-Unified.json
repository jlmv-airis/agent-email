    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT c.*, g.nombre as nombre_grupo FROM cuentas_email c LEFT JOIN grupos g ON c.grupo_id = g.id ORDER BY c.email ASC;"
      },
